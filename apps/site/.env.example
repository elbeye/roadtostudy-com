# EmDash / Cloudflare
EMDASH_ENCRYPTION_KEY=
CLOUDFLARE_API_TOKEN=

# WordPress REST API extraction (scripts/wp-export-sample.mjs)
WP_BASE_URL=https://roadtostudy.com
WP_USERNAME=
WP_APPLICATION_PASSWORD=

# Media upload (scripts/wp-media-to-r2.mjs) uploads via `wrangler r2 object put`,
# which authenticates with CLOUDFLARE_API_TOKEN above — no separate R2 S3 keys needed.
# Only the bucket name is configurable (defaults to the value below).
R2_BUCKET=roadtostudy-emdash-media-poc
