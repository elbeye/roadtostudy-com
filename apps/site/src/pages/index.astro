---
import { getEmDashCollection, getTaxonomyTerms, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import PortalHome from "../components/PortalHome.astro";
import { categoryPath } from "../utils/content-url";
import { resolveBlogSiteIdentity } from "../utils/site-identity";

// TR is the unprefixed default locale. The home is a guide portal: prominent search,
// topic cards (real category taxonomy), and a "Son yazılar" (latest posts) grid.
// Posts are filtered to the TR locale so the Turkish home doesn't mix in EN/FR/ID articles.
const locale = "tr";
const HEADING = "Türkiye'de okumak için rehberin";
const SUMMARY =
	"Üniversite seçiminden bursa, vizeden öğrenci hayatına — uluslararası öğrenciler için güncel rehberler.";

const [{ entries: posts, cacheHint }, terms, settings] = await Promise.all([
	getEmDashCollection("posts", { orderBy: { published_at: "desc" }, limit: 6, locale }),
	getTaxonomyTerms("category", { locale }),
	getSiteSettings(),
]);

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const { siteTitle } = resolveBlogSiteIdentity(settings);

const categories = (terms || [])
	.filter((term: any) => term.locale === locale && term.slug)
	.map((term: any) => ({ href: categoryPath(locale, term.slug), label: term.label }));
---

<Base title={siteTitle} description={SUMMARY} lang={locale}>
	{
		posts.length === 0 && categories.length === 0 ? (
			<section class="empty-state">
				<h2>Henüz içerik yok</h2>
				<p>Yönetim panelinden ilk yazını oluştur.</p>
				<a href="/_emdash/admin/content/posts/new" class="btn">
					Yazı oluştur
				</a>
			</section>
		) : (
			<PortalHome
				locale={locale}
				heading={HEADING}
				summary={SUMMARY}
				categories={categories}
				posts={posts}
			/>
		)
	}
</Base>

<style>
	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-3);
		text-align: center;
		padding: var(--spacing-20) var(--spacing-6);
		max-width: 400px;
		margin: 0 auto;
	}

	.empty-state h2 {
		font-size: var(--font-size-2xl);
		font-weight: 600;
	}

	.empty-state p {
		color: var(--color-muted);
	}

	.btn {
		display: inline-block;
		margin-top: var(--spacing-4);
		padding: var(--spacing-3) var(--spacing-6);
		background: var(--color-accent);
		color: var(--color-on-accent);
		text-decoration: none;
		border-radius: var(--radius);
		font-size: var(--font-size-sm);
		font-weight: 500;
	}

	.btn:hover {
		background: var(--color-accent-hover);
	}
</style>
