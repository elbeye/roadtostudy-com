---
import { getEmDashCollection, getTermsForEntries } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { contentPath } from "../../utils/content-url";
import { getReadingTime } from "../../utils/reading-time";

// This route is unprefixed (/posts) — the site default locale is TR, and the
// vast majority of the migrated corpus is Turkish, so the page is TR-primary
// chrome. Individual entries may still carry their own locale (mixed-locale
// corpus), which is why PostCard below is given each entry's own locale
// rather than a hardcoded "tr".
const locale = "tr";

// Sort in the database rather than in JS — lets the DB use its index on
// published_at and avoids a full-table scan on the client.
// Capped: with the full migrated corpus (2200+ published posts) an unbounded
// render exceeds the Worker CPU limit (Cloudflare error 1102). 24 image cards
// (vs. the previous 100 plain-text rows) keeps the page well under budget.
const POSTS_PAGE_LIMIT = 24;
const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: POSTS_PAGE_LIMIT,
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

// Single batched query for tags across all posts, instead of one
// getEntryTerms() call per post (which would be N round-trips).
const tagsByEntry = await getTermsForEntries(
	"posts",
	posts.map((p) => p.data.id),
	"tag",
);
---

<Base title="Tüm Yazılar" description="Tüm blog yazılarına göz atın">
	<div class="posts-page">
		<header class="page-header">
			<h1 class="page-title">Tüm Yazılar</h1>
			<p class="page-description">
				Son {posts.length} yazı
			</p>
		</header>

		{
			posts.length === 0 ? (
				<p class="empty">Henüz yazı yok.</p>
			) : (
				<div class="posts-grid">
					{posts.map((post) => (
						<PostCard
							title={post.data.title}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={contentPath((post.data as any).locale || locale, post.data.slug || post.id)}
							date={post.data.wp_published_at ?? post.data.publishedAt ?? undefined}
							locale={(post.data as any).locale || locale}
							readingTime={getReadingTime(post.data.content)}
							tags={tagsByEntry.get(post.data.id)}
						/>
					))}
				</div>
			)
		}
	</div>
</Base>

<style>
	.posts-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-10) var(--spacing-6) var(--spacing-16);
	}

	.page-header {
		margin-bottom: var(--spacing-10);
		padding-bottom: var(--spacing-8);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.page-title {
		font-size: var(--font-size-4xl);
		font-weight: 700;
		letter-spacing: 0;
		margin-bottom: var(--spacing-2);
	}

	.page-description {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
	}

	.empty {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-10) var(--spacing-8);
	}

	@media (max-width: 900px) {
		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.posts-page {
			padding: var(--spacing-6) var(--spacing-4) var(--spacing-12);
		}

		.page-header {
			padding-bottom: var(--spacing-5);
			margin-bottom: var(--spacing-8);
		}

		.page-title {
			font-size: var(--font-size-3xl);
		}

		.posts-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}
	}
</style>
