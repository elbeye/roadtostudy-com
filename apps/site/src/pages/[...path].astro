---
import {
	decodeSlug,
	getEmDashCollection,
	getEmDashEntry,
	getSeoMeta,
	getSiteSettings,
	getTerm,
	getTermsForEntries,
} from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { categoryPath, contentPath } from "../utils/content-url";
import { contentAlternates } from "../utils/hreflang";
import { getReadingTime } from "../utils/reading-time";
import { resolveBlogSiteIdentity } from "../utils/site-identity";
import { rewriteSourceHost } from "../utils/source-host";

const LOCALES = new Set(["en", "fr", "id"]);

// Rank Math emits this exact robots directive on every indexable page. Matching it
// keeps the migrated pages' robots meta identical (SEO parity §6.3).
const DEFAULT_ROBOTS = "follow, index, max-snippet:-1, max-video-preview:-1, max-image-preview:large";

// WordPress archive pagination (§6.1: /page/N/ must resolve). 10 is the WordPress
// default posts_per_page; the source theme's value is unconfirmed in the export, so
// keep it a single knob to correct once verified against the live archives.
const CATEGORY_PAGE_SIZE = 10;
// Number of latest posts shown on a localized language home (/en/, /fr/, /id/).
const LOCALE_HOME_LIMIT = 12;
// hreflang ordering for the language-home cluster; x-default points at EN (§6.5).
const HOME_LOCALE_ORDER = ["en", "tr", "fr", "id"] as const;
// Minimal localized landing copy for the language homes. TR is included for
// completeness even though the unprefixed root (/) is served by index.astro.
const HOME_COPY: Record<string, { heading: string; summary: string }> = {
	tr: { heading: "Türkiye'de Eğitim", summary: "Uluslararası öğrenciler için üniversite, burs ve öğrenci yaşamı rehberleri." },
	en: { heading: "Study in Turkey", summary: "Guides on universities, scholarships, and student life for international students." },
	fr: { heading: "Étudier en Turquie", summary: "Guides sur les universités, les bourses et la vie étudiante pour les étudiants internationaux." },
	id: { heading: "Kuliah di Turki", summary: "Panduan universitas, beasiswa, dan kehidupan mahasiswa untuk mahasiswa internasional." },
};

// Language-home path: TR is unprefixed (/), other locales are /{locale}/.
const localeHomePath = (l: string) => (l === "tr" ? "/" : `/${l}/`);

function parsePath(pathParam: string | undefined) {
	const segments = (pathParam || "").split("/").filter(Boolean).map(decodeSlug);
	if (segments.length === 0) return null;
	if (LOCALES.has(segments[0] || "")) {
		return { locale: segments[0], segments: segments.slice(1), prefix: `/${segments[0]}` };
	}
	return { locale: "tr", segments, prefix: "" };
}

function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http") ? image.src : `${Astro.url.origin}${image.src}`;
	}
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	return storageKey ? `${Astro.url.origin}/_emdash/api/media/file/${storageKey}` : undefined;
}

const parsed = parsePath(Astro.params.path);
if (!parsed) return Astro.redirect("/404");

const locale: string = parsed.locale || "tr";
const hasLocalePrefix = parsed.prefix !== "";
let segments: string[] = parsed.segments.filter((segment): segment is string => !!segment);

// Strip a trailing /page/N/ archive pagination suffix (§6.1) so the resolver sees
// the base path; N drives the slice. A non-numeric or <1 page is not a valid URL.
let pageNum = 1;
if (segments.length >= 2 && segments[segments.length - 2] === "page") {
	const n = Number(segments[segments.length - 1]);
	if (!Number.isInteger(n) || n < 1) return Astro.redirect("/404");
	pageNum = n;
	segments = segments.slice(0, -2);
}

const [first, second] = segments;
let view: "home" | "post" | "page" | "category" | "tag" | null = null;
let slug = "";
let post: any = null;
let page: any = null;
let term: any = null;
let termPosts: any[] = [];
let termPostCount = 0;
let termTotalPages = 1;
let termTagsByEntry = new Map<string, Array<{ slug: string; label: string }>>();
let homePosts: any[] = [];

// `/category/{slug}` and `/tag/{slug}` (plus their /{locale}/ prefixed forms) are
// both taxonomy archives; the taxonomy name matches the query key exactly (seed
// "name" field) per the taxonomy-naming rule.
const taxonomyView = first === "category" ? "category" : first === "tag" ? "tag" : null;

if (segments.length === 0) {
	// Localized language home (/en/, /fr/, /id/). The unprefixed root (/) is served
	// by index.astro, so only locale-prefixed homes reach the catch-all. The home is
	// a bespoke landing layout and isn't paginated, so /{locale}/page/N/ is not valid.
	if (hasLocalePrefix && pageNum === 1) {
		const result = await getEmDashCollection("posts", {
			orderBy: { published_at: "desc" },
			limit: LOCALE_HOME_LIMIT,
			locale,
		});
		if (Astro.cache?.enabled) Astro.cache.set(result.cacheHint);
		homePosts = result.entries;
		view = "home";
	}
} else if (taxonomyView && second && segments.length === 2) {
	slug = second;
	term = await getTerm(taxonomyView, slug, { locale });
	if (term) {
		const result = await getEmDashCollection("posts", {
			where: { [taxonomyView]: term.slug },
			orderBy: { published_at: "desc" },
			locale,
		});
		if (Astro.cache?.enabled) Astro.cache.set(result.cacheHint);
		const allTermPosts = result.entries;
		termPostCount = allTermPosts.length;
		termTotalPages = Math.max(1, Math.ceil(termPostCount / CATEGORY_PAGE_SIZE));
		// Out-of-range archive page → 404 (an empty archive still has a valid page 1).
		if (pageNum > termTotalPages) return Astro.redirect("/404");
		termPosts = allTermPosts.slice((pageNum - 1) * CATEGORY_PAGE_SIZE, pageNum * CATEGORY_PAGE_SIZE);
		// Restore the per-card tag chips the standalone archive routes rendered:
		// one batched query rather than getEntryTerms() per post.
		const tags = await getTermsForEntries(
			"posts",
			termPosts.map((entry: any) => entry.data.id),
			"tag",
		);
		termTagsByEntry = new Map(
			termPosts.map((entry: any) => [
				entry.data.id,
				(tags.get(entry.data.id) ?? []).map((t: any) => ({ slug: t.slug, label: t.label })),
			]),
		);
		view = taxonomyView;
	}
} else if (first && segments.length === 1 && pageNum === 1) {
	// Posts and pages are single URLs, never paginated: /{slug}/page/N/ is not valid.
	slug = first;
	const postResult = await getEmDashEntry("posts", slug, { locale });
	post = postResult.entry;
	if (post) {
		if (Astro.cache?.enabled) Astro.cache.set(postResult.cacheHint);
		view = "post";
	} else {
		const pageResult = await getEmDashEntry("pages", slug, { locale });
		page = pageResult.entry;
		if (page) {
			if (Astro.cache?.enabled) Astro.cache.set(pageResult.cacheHint);
			view = "page";
		}
	}
}

if (!view) return Astro.redirect("/404");

const { siteTitle } = resolveBlogSiteIdentity(await getSiteSettings());
const resolvedSlug: string = slug || "";
const canonical = `${Astro.url.origin}${contentPath(locale, resolvedSlug)}`;
const currentPost = post;
const currentPage = page;
const currentTerm = term;
const pageTitle =
	view === "post"
		? currentPost.data.title
		: view === "page"
			? currentPage.data.title
			: view === "home"
				? (HOME_COPY[locale]?.heading ?? siteTitle)
				: view === "tag"
					? `Posts tagged "${currentTerm.label}"`
					: `${currentTerm.label} posts`;
// Rank Math appends " – Page N" to paginated archive titles.
const pagedTitle = pageNum > 1 ? `${pageTitle} – Page ${pageNum}` : pageTitle;
// Self-referential canonical for the current archive page (§6.1). Page 1 keeps the
// bare /category/{slug}/ form; deeper pages append /page/N/.
const categoryPagePath = (n: number) =>
	`${Astro.url.origin}${categoryPath(locale, resolvedSlug)}${n > 1 ? `page/${n}/` : ""}`;
const homeCanonical = `${Astro.url.origin}${localeHomePath(locale)}`;
// hreflang cluster across the four language homes (+ x-default → EN, §6.5).
const homeAlternates = [
	...HOME_LOCALE_ORDER.map((l) => ({ hreflang: l, href: `${Astro.url.origin}${localeHomePath(l)}` })),
	{ hreflang: "x-default", href: `${Astro.url.origin}${localeHomePath("en")}` },
];
const featuredImageUrl = view === "post" ? getImageUrl(currentPost.data.featured_image) : undefined;
const seo =
	view === "post"
		? getSeoMeta(currentPost, {
				siteTitle,
				siteUrl: Astro.url.origin,
				path: contentPath(locale, resolvedSlug),
				defaultOgImage: featuredImageUrl,
			})
		: null;
// Verbatim source (Rank Math) head, when migrated. Rendered exactly to preserve SEO.
const sourceSeo: any =
	view === "post" ? currentPost.data.source_seo : view === "page" ? currentPage.data.source_seo : null;
const absoluteOg = (path: string | null | undefined) =>
	path ? new URL(path, Astro.url.origin).href : undefined;
// Body HTML is stored verbatim; rewrite the source host to the current origin so
// in-body image/link URLs resolve here (pre-cutover) and stay identical at cutover
// (origin === roadtostudy.com then). Media loads via the /wp-content/uploads/ route.
const bodyHtml = (html: string | null | undefined) => rewriteSourceHost(html, Astro.url.origin);
// Original WP dates (§9) may arrive as ISO strings or Date objects.
const toIsoDate = (v: unknown): string | null => {
	if (!v) return null;
	const d = v instanceof Date ? v : new Date(v as string);
	return Number.isNaN(d.getTime()) ? null : d.toISOString();
};
const alternates =
	view === "post"
		? await contentAlternates("posts", currentPost.data.id, Astro.url.origin, {
				locale,
				slug: resolvedSlug,
			})
		: view === "page"
			? await contentAlternates("pages", currentPage.data.id, Astro.url.origin, {
					locale,
					slug: resolvedSlug,
				})
			: view === "home"
				? homeAlternates
				: [];
---

{
	view === "post" && (
		<Base
			title={sourceSeo?.title || seo?.title || currentPost.data.title}
			exactTitle={!!sourceSeo?.title}
			pageTitle={sourceSeo?.ogTitle || seo?.ogTitle}
			description={sourceSeo?.description || seo?.description}
			image={absoluteOg(sourceSeo?.ogImage) || seo?.ogImage}
			canonical={seo?.canonical || canonical}
			lang={locale}
			alternates={alternates}
			robots={sourceSeo?.robots || seo?.robots || DEFAULT_ROBOTS}
			jsonLd={sourceSeo?.jsonLd}
			type="article"
			publishedTime={toIsoDate(currentPost.data.wp_published_at) ?? currentPost.data.publishedAt?.toISOString() ?? null}
			modifiedTime={toIsoDate(currentPost.data.wp_modified_at) ?? currentPost.data.updatedAt.toISOString()}
			content={{ collection: "posts", id: currentPost.data.id, slug: resolvedSlug }}
		>
			<article class="wp-content article">
				{currentPost.data.featured_image && (
					<div class="wp-hero">
						<Image image={currentPost.data.featured_image} />
					</div>
				)}
				<header class="wp-header">
					<p class="wp-meta">{getReadingTime(currentPost.data.content)} min read</p>
					<h1>{currentPost.data.title}</h1>
					{currentPost.data.excerpt && <p class="wp-excerpt">{currentPost.data.excerpt}</p>}
				</header>
				{currentPost.data.content_html ? (
					<div class="wp-body" set:html={bodyHtml(currentPost.data.content_html)} />
				) : (
					<div class="wp-body">
						<PortableText value={currentPost.data.content} />
					</div>
				)}
			</article>
		</Base>
	)
}

{
	view === "page" && (
		<Base
			title={sourceSeo?.title || currentPage.data.title}
			exactTitle={!!sourceSeo?.title}
			pageTitle={sourceSeo?.ogTitle}
			description={sourceSeo?.description}
			image={absoluteOg(sourceSeo?.ogImage)}
			canonical={canonical}
			lang={locale}
			alternates={alternates}
			robots={sourceSeo?.robots || DEFAULT_ROBOTS}
			jsonLd={sourceSeo?.jsonLd}
			content={{ collection: "pages", id: currentPage.data.id, slug: resolvedSlug }}
		>
			<article class="wp-content">
				<header class="wp-header">
					<h1>{currentPage.data.title}</h1>
				</header>
				{currentPage.data.content_html ? (
					<div class="wp-body" set:html={bodyHtml(currentPage.data.content_html)} />
				) : (
					<div class="wp-body">
						<PortableText value={currentPage.data.content} />
					</div>
				)}
			</article>
		</Base>
	)
}

{
	(view === "category" || view === "tag") && (
		<Base
			title={pagedTitle}
			description={
				view === "tag"
					? `All posts tagged with ${currentTerm.label}`
					: `All posts in ${currentTerm.label}`
			}
			canonical={view === "category" ? categoryPagePath(pageNum) : undefined}
			manualCanonical={view === "category"}
			lang={locale}
			robots={DEFAULT_ROBOTS}
		>
			<section class="wp-archive">
				<header class="wp-header">
					<p class="wp-meta">{view === "tag" ? "Tag" : "Category"}</p>
					<h1>{currentTerm.label}</h1>
					<p class="wp-excerpt">
						{termPostCount} {termPostCount === 1 ? "post" : "posts"}
					</p>
				</header>
				<div class="wp-grid">
					{termPosts.map((entry) => (
						<PostCard
							title={entry.data.title}
							excerpt={entry.data.excerpt}
							featuredImage={entry.data.featured_image}
							href={contentPath(entry.data.locale || locale, entry.data.slug || entry.id)}
							date={entry.data.publishedAt ?? undefined}
							readingTime={getReadingTime(entry.data.content)}
							tags={termTagsByEntry.get(entry.data.id)}
						/>
					))}
				</div>
				{termTotalPages > 1 && (
					<nav class="wp-pagination" aria-label="Archive pagination">
						{pageNum > 1 ? (
							<a rel="prev" href={categoryPagePath(pageNum - 1)}>
								← Newer
							</a>
						) : (
							<span class="wp-pagination-spacer" />
						)}
						<span class="wp-pagination-status">
							Page {pageNum} of {termTotalPages}
						</span>
						{pageNum < termTotalPages ? (
							<a rel="next" href={categoryPagePath(pageNum + 1)}>
								Older →
							</a>
						) : (
							<span class="wp-pagination-spacer" />
						)}
					</nav>
				)}
			</section>
		</Base>
	)
}

{
	view === "home" && (
		<Base
			title={pageTitle}
			description={HOME_COPY[locale]?.summary}
			canonical={homeCanonical}
			manualCanonical
			lang={locale}
			alternates={alternates}
			robots={DEFAULT_ROBOTS}
		>
			<section class="wp-archive">
				<header class="wp-header">
					<p class="wp-meta">RoadToStudy</p>
					<h1>{HOME_COPY[locale]?.heading ?? siteTitle}</h1>
					{HOME_COPY[locale]?.summary && <p class="wp-excerpt">{HOME_COPY[locale]?.summary}</p>}
				</header>
				<div class="wp-grid">
					{homePosts.map((entry) => (
						<PostCard
							title={entry.data.title}
							excerpt={entry.data.excerpt}
							featuredImage={entry.data.featured_image}
							href={contentPath(entry.data.locale || locale, entry.data.slug || entry.id)}
							date={entry.data.publishedAt ?? undefined}
							readingTime={getReadingTime(entry.data.content)}
						/>
					))}
				</div>
			</section>
		</Base>
	)
}

<style>
	.wp-pagination {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--spacing-4);
		margin-top: var(--spacing-12);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border-subtle);
	}

	.wp-pagination a {
		font-weight: 600;
		text-decoration: none;
		color: var(--color-accent);
	}

	.wp-pagination a:hover {
		color: var(--color-accent-hover);
	}

	.wp-pagination-status {
		color: var(--color-muted);
		font-size: var(--font-size-sm);
	}

	.wp-pagination-spacer {
		width: 1px;
	}
</style>

<style>
	.wp-content {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-10) var(--spacing-6) var(--spacing-16);
	}

	.wp-hero {
		margin: 0 auto var(--spacing-8);
		max-width: min(var(--wide-width), calc(100vw - (var(--spacing-6) * 2)));
		overflow: hidden;
		border-radius: var(--radius-lg);
		background: var(--color-surface);
		border: 1px solid var(--color-border-subtle);
	}

	.wp-hero :global(img) {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
	}

	.wp-header {
		margin-bottom: var(--spacing-8);
	}

	.wp-header h1 {
		font-size: var(--font-size-4xl);
		line-height: var(--leading-tight);
		letter-spacing: 0;
		margin: 0;
	}

	.wp-meta {
		color: var(--color-muted);
		font-size: var(--font-size-sm);
		margin-bottom: var(--spacing-2);
	}

	.wp-excerpt {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
		margin-top: var(--spacing-4);
		line-height: var(--leading-relaxed);
	}

	.wp-body {
		font-size: var(--font-size-lg);
		line-height: 1.75;
	}

	.wp-body :global(p),
	.wp-body :global(ul),
	.wp-body :global(ol) {
		margin-bottom: 1.35em;
	}

	.wp-body :global(a) {
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.18em;
	}

	.wp-body :global(h2),
	.wp-body :global(h3) {
		margin-top: 1.8em;
		margin-bottom: 0.7em;
		letter-spacing: 0;
	}

	.wp-body :global(h2) {
		font-size: var(--font-size-2xl);
	}

	.wp-body :global(h3) {
		font-size: var(--font-size-xl);
	}

	.wp-body :global(img),
	.wp-body :global(video),
	.wp-body :global(iframe) {
		max-width: 100%;
		border-radius: var(--radius-lg);
	}

	.wp-body :global(figure) {
		margin: var(--spacing-8) 0;
	}

	.wp-body :global(table) {
		display: block;
		width: 100%;
		overflow-x: auto;
		border-collapse: collapse;
	}

	.wp-body :global(blockquote) {
		margin: var(--spacing-8) 0;
		padding: var(--spacing-4) var(--spacing-5);
		border-left: 4px solid var(--color-accent);
		background: var(--color-bg-subtle);
		color: var(--color-text-secondary);
		border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
	}

	.wp-archive {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-12) var(--spacing-6) var(--spacing-16);
	}

	.wp-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-10) var(--spacing-8);
	}

	@media (max-width: 900px) {
		.wp-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		.wp-content,
		.wp-archive {
			padding: var(--spacing-6) var(--spacing-4) var(--spacing-12);
		}

		.wp-hero {
			max-width: none;
			margin-bottom: var(--spacing-6);
			border-radius: var(--radius-lg);
		}

		.wp-header h1 {
			font-size: var(--font-size-3xl);
		}

		.wp-excerpt,
		.wp-body {
			font-size: var(--font-size-base);
		}

		.wp-body :global(h2) {
			font-size: var(--font-size-xl);
		}

		.wp-body :global(h3) {
			font-size: var(--font-size-lg);
		}

		.wp-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}
	}
</style>
