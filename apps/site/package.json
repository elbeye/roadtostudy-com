{
  "name": "roadtostudy-emdash",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "emdash": {
    "label": "RoadToStudy",
    "seed": "seed/runtime.json"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/wp-runtime-seed.mjs && astro build",
    "preview": "astro preview",
    "deploy": "node scripts/wp-runtime-seed.mjs && astro build && wrangler deploy --config dist/server/wrangler.json",
    "typecheck": "astro check",
    "load:test": "node scripts/load-test.mjs",
    "wp:sample": "node --env-file=.env scripts/wp-export-sample.mjs",
    "wp:seed": "node scripts/wp-sample-to-emdash-seed.mjs",
    "wp:seed:full": "WP_SAMPLE_INPUT=data/wp-full.json WP_SEED_MEDIA_REFERENCES=1 node scripts/wp-sample-to-emdash-seed.mjs",
    "wp:seed:runtime": "node scripts/wp-runtime-seed.mjs",
    "wp:seed:preflight": "node scripts/wp-seed-preflight.mjs",
    "wp:d1:seed-sql": "node scripts/wp-sqlite-to-d1-seed-sql.mjs",
    "media:upload": "node --env-file=.env scripts/wp-media-to-r2.mjs",
    "media:dry-run:full": "WP_SAMPLE_INPUT=data/wp-full.json node scripts/wp-media-to-r2.mjs --dry-run",
    "media:size:full": "WP_SAMPLE_INPUT=data/wp-full.json node scripts/wp-media-size-report.mjs",
    "media:upload:full": "WP_SAMPLE_INPUT=data/wp-full.json node --env-file=.env scripts/wp-media-to-r2.mjs",
    "media:upload:full:confirmed": "WP_SAMPLE_INPUT=data/wp-full.json node --env-file=.env scripts/wp-media-to-r2.mjs --confirm-cost --force",
    "test": "node --test scripts/*.test.mjs && node --experimental-strip-types --test src/lib/*.test.ts",
    "wp:full": "node --env-file=.env scripts/wp-export-full.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.7.0",
    "@astrojs/react": "5.0.7",
    "@emdash-cms/cloudflare": "0.24.1",
    "astro": "6.4.8",
    "emdash": "0.24.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@cloudflare/workers-types": "4.20260630.1",
    "better-sqlite3": "12.11.1",
    "wrangler": "4.105.0"
  },
  "overrides": {
    "vite": "7.3.6"
  }
}
